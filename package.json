{
  "name": "exceltools",
  "version": "1.0.0",
  "description": "将 Excel 配置表转换为 JSON 数据文件，并使用 Liquid 模板生成多语言代码",
  "main": "dist/index.js",
  "bin": {
    "exceltools": "./dist/bin/exceltools.js"
  },
  "scripts": {
    "dev": "tsx bin/exceltools.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "cosmiconfig": "^9.0.0",
