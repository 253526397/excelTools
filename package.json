    "liquidjs": "^10.20.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/json5": "^0.0.30",
    "@types/node": "^22.13.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
