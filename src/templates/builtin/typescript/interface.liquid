// 自动生成于 {{ sourceFile }} 时间: {{ generatedAt }}
// 表: {{ tableName }}
// 请勿手动编辑此文件
{%- if importedEnums.size > 0 %}
import { {{ importedEnums | join: ', ' }} } from './{{ enumFileName }}';
{%- endif %}

export interface I{{ tableName }} {
{%- for field in fields %}
{%- if field.comment and field.comment != "" %}
  /** {{ field.comment }} */
{%- endif %}
  {{ field.propertyName }}{% unless field.isArray or field.is2DArray %}?{% endunless %}: {{ field.mappedType }};
{%- endfor %}
}

export class {{ tableName }} implements I{{ tableName }} {
{%- for field in fields %}
{%- if field.comment and field.comment != "" %}
  /** {{ field.comment }} */
{%- endif %}
  {{ field.propertyName }}{% unless field.isArray or field.is2DArray %}?{% endunless %}: {{ field.mappedType }}{% if field.is2DArray %} = []{% elsif field.isArray %} = []{% endif %};
{%- endfor %}

  private static _dataMap: Record<string, I{{ tableName }}> = {};

  /** 数据 Map，key = {{ keyFieldName }}，可直接 for...in / Object.keys 遍历 */
  public static get dataMap(): Record<string, I{{ tableName }}> {
    return {{ tableName }}._dataMap;
  }

  /** 根据 {{ keyFieldName }} 查询 */
  public static Get(key: number | string): I{{ tableName }} | undefined {
    return {{ tableName }}.dataMap[String(key)];
  }

  /** 从 JSON 数据加载（自动兼容 verbose / compact / 纯数组格式） */
  public static parseData(obj: any): void {
    // verbose 格式: { tableName, fields, data[{...}, ...] } → 取 data
    // compact 格式: { t, f[[name,type,comment],...], d[[val,...],...] } → 取 d + f 重建对象
    // 纯数组格式: [{...}, ...] → 直接使用
    let rows: any[];
    if (Array.isArray(obj)) {
      rows = obj;
    } else if (obj && Array.isArray(obj.data)) {
      rows = obj.data;
    } else if (obj && Array.isArray(obj.d)) {
      // compact 格式：列式数据 → 对象数组
      const fieldNames: string[] = obj.f?.map((f: any[]) => f[0]) ?? {{ fieldNames }};
      rows = obj.d.map((vals: any[]) => {
        const row: any = {};
        for (let i = 0; i < fieldNames.length; i++) {
          row[fieldNames[i]] = vals[i];
        }
        return row;
      });
    } else {
      // 已经是 key→value 映射
      {{ tableName }}._dataMap = obj;
      return;
    }
    const map: Record<string, I{{ tableName }}> = {};
    for (const row of rows) {
      map[String(row.{{ keyFieldName }})] = row as I{{ tableName }};
    }
    {{ tableName }}._dataMap = map;
  }
}
