{
  "rowMapping": {
    "fieldNames": 0,
    "dataTypes": 1,
    "comments": 2,
    "dataStart": 3
  },
  "languages": [
    "typescript",
    "csharp",
    "java"
  ],
  "output": {
    "json": "./output/json",
    "code": "./output/code"
  },
  "templates": {
    "customDir": null,
    "overrides": {}
  },
  "enums": {
    "SkillType": {
      "Attack": 1,
      "Defense": 2,
      "Heal": 3,
      "Buff": 4
    }
  },
  "excludeSheets": [],
  "naming": {
    "sheetNameToTableName": "PascalCase",
    "fieldNameToPropertyName": "camelCase"
  },
  "languageSettings": {
    "typescript": {
      "generateEnums": true,
      "useStringEnum": false
    },
    "csharp": {
      "namespace": "GameConfig",
      "generateEnums": true,
      "useJsonProperty": true
    },
    "java": {
      "package": "com.game.config",
      "generateEnums": true,
      "useLombok": false,
      "useJackson": false
    }
  },
  "verbose": false
}